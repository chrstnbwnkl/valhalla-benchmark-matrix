    OUTFILE="$OUT_DIR/$outdir/${prefix}_${n}.json"
    OUTGEOJSON="$OUT_DIR/$outdir/${prefix}_${n}.geojson"
    if [ ! -f "$OUTFILE" ]; then
        if ! python "$MATRIX_SCRIPT" "$place" "$n" --partial "$PARTIAL" --cache-dir "$CACHE_DIR" --points-csv "$POINTS_CSV" > $OUTFILE; then
            echo "FAILED: $place" >&2
            rm -f "$outdir/${prefix}_${n}.json"
        else 
          cat $OUTFILE | s2tlocs > $OUTGEOJSON
        fi
        sleep 1 # respect Nominatims request limits
    else 
        cat $OUTFILE | s2tlocs > $OUTGEOJSON
    fi
done
 
